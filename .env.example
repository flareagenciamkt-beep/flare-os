# Plantilla de variables de entorno de Flare OS.
# Copia este archivo a `.env.local` y completa los valores reales.
# `.env.local` está git-ignorado: las credenciales nunca se versionan.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# OPCIONAL — habilita crear usuarios del portal desde la app.
# Supabase → Settings → API Keys → "secret key" (sb_secret_...).
# SIN prefijo NEXT_PUBLIC_: solo la lee el servidor (route handlers), nunca
# llega al navegador. NUNCA la pegues en código ni en variables NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_...tu-secret-key

# OPCIONAL — credenciales de Meta como variables de entorno (fallback).
# La forma recomendada es pegarlas en la app: Ajustes → Integraciones (quedan
# guardadas en la tabla server-only integration_settings, sin tocar código).
# Estas variables solo se usan si la base no tiene credenciales guardadas.
# META_APP_ID=...id-de-tu-app
# META_APP_SECRET=...secret-de-tu-app
# Solo si el dominio público difiere del origen de la app (default: /api/integrations/meta/callback)
# META_OAUTH_REDIRECT_URL=https://tu-dominio.com/api/integrations/meta/callback
