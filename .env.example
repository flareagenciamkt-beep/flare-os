# Plantilla de variables de entorno de Flare OS.
# Copia este archivo a `.env.local` y completa los valores reales.
# `.env.local` está git-ignorado: las credenciales nunca se versionan.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# OPCIONAL — habilita crear usuarios del portal desde la app.
# Supabase → Settings → API Keys → "secret key" (sb_secret_...).
# SIN prefijo NEXT_PUBLIC_: solo la lee el servidor (route handlers), nunca
# llega al navegador. NUNCA la pegues en código ni en variables NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_...tu-secret-key
